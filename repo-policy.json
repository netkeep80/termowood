{
  "policy_format_version": "0.3.0",
  "repository_kind": "application",
  "enforcement": {
    "mode": "blocking"
  },
  "paths": {
    "forbidden": [
      "*.bak",
      "*.log"
    ],
    "canonical_docs": [
      "README.md"
    ],
    "governance_paths": [
      "repo-policy.json",
      ".github/workflows/repo-guard.yml",
      ".github/PULL_REQUEST_TEMPLATE.md",
      ".github/ISSUE_TEMPLATE/"
    ]
  },
  "diff_rules": {
    "max_new_docs": 3,
    "max_new_files": 20,
    "max_net_added_lines": 1500
  },
  "content_rules": [],
  "cochange_rules": []
}
